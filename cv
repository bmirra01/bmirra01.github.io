<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bruno Mirrado | Frontend Developer</title>
    <meta name="description" content="Bruno Mirrado — Frontend Developer specializing in React, TypeScript, Azure, and CI/CD. Portfolio and CV.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0a0e14;
            --bg-secondary: #0d1117;
            --bg-card: #111820;
            --bg-terminal: #0c1018;
            --border: #1c2533;
            --border-glow: #2d9bf0;
            --text-primary: #c9d1d9;
            --text-secondary: #8b949e;
            --text-muted: #484f58;
            --accent-blue: #58a6ff;
            --accent-green: #3fb950;
            --accent-orange: #d29922;
            --accent-red: #f85149;
            --accent-purple: #bc8cff;
            --accent-cyan: #39d2c0;
            --prompt-green: #3fb950;
            --glow-blue: rgba(88, 166, 255, 0.15);
            --glow-green: rgba(63, 185, 80, 0.1);
            --font-mono: 'JetBrains Mono', 'IBM Plex Mono', 'Fira Code', monospace;
            --font-display: 'Space Grotesk', sans-serif;
        }

        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        ::selection {
            background: var(--accent-blue);
            color: var(--bg-primary);
        }

        html {
            scroll-behavior: smooth;
            scrollbar-width: thin;
            scrollbar-color: var(--border) var(--bg-primary);
        }

        body {
            font-family: var(--font-mono);
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* Scanline overlay */
        body::after {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0, 0, 0, 0.03) 2px,
                rgba(0, 0, 0, 0.03) 4px
            );
            pointer-events: none;
            z-index: 9999;
        }

        /* Noise texture */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9998;
        }

        a {
            color: var(--accent-blue);
            text-decoration: none;
            transition: color 0.2s;
        }
        a:hover {
            color: var(--accent-cyan);
        }

        /* ═══════════════ NAV ═══════════════ */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            background: rgba(10, 14, 20, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0 2rem;
        }

        .nav-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 56px;
        }

        .nav-logo {
            font-family: var(--font-mono);
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--accent-green);
        }
        .nav-logo span { color: var(--text-muted); }

        .nav-links {
            display: flex;
            gap: 0.25rem;
            list-style: none;
        }

        .nav-links a {
            font-size: 0.78rem;
            color: var(--text-secondary);
            padding: 0.4rem 0.75rem;
            border-radius: 4px;
            transition: all 0.2s;
            font-weight: 400;
        }
        .nav-links a:hover {
            color: var(--accent-blue);
            background: var(--glow-blue);
        }

        .nav-toggle {
            display: none;
            background: none;
            border: 1px solid var(--border);
            color: var(--text-secondary);
            padding: 0.4rem;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1.2rem;
        }

        /* ═══════════════ HERO ═══════════════ */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 6rem 2rem 4rem;
            position: relative;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background:
                radial-gradient(ellipse 600px 400px at 15% 50%, rgba(63, 185, 80, 0.06), transparent),
                radial-gradient(ellipse 500px 500px at 85% 30%, rgba(88, 166, 255, 0.04), transparent);
            pointer-events: none;
        }

        .hero-inner {
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        .hero-terminal {
            background: var(--bg-terminal);
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 0 60px rgba(0,0,0,0.4), 0 0 1px var(--border);
        }

        .terminal-bar {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            background: rgba(255,255,255,0.02);
            border-bottom: 1px solid var(--border);
            gap: 0.5rem;
        }

        .terminal-dot {
            width: 12px; height: 12px;
            border-radius: 50%;
        }
        .terminal-dot.red { background: var(--accent-red); }
        .terminal-dot.yellow { background: var(--accent-orange); }
        .terminal-dot.green { background: var(--accent-green); }

        .terminal-title {
            font-size: 0.72rem;
            color: var(--text-muted);
            margin-left: 0.75rem;
        }

        .terminal-body {
            padding: 2rem 2.5rem 2.5rem;
        }

        .hero-line {
            margin-bottom: 0.3rem;
            font-size: 0.85rem;
            opacity: 0;
            animation: typeIn 0.4s ease forwards;
        }

        .hero-line .prompt {
            color: var(--accent-green);
            font-weight: 600;
        }
        .hero-line .path {
            color: var(--accent-blue);
        }
        .hero-line .cmd {
            color: var(--text-primary);
        }
        .hero-line .flag {
            color: var(--accent-orange);
        }
        .hero-line .string {
            color: var(--accent-cyan);
        }
        .hero-line .comment {
            color: var(--text-muted);
            font-style: italic;
        }

        .hero-line:nth-child(1) { animation-delay: 0.2s; }
        .hero-line:nth-child(2) { animation-delay: 0.5s; }
        .hero-line:nth-child(3) { animation-delay: 0.8s; }
        .hero-line:nth-child(4) { animation-delay: 1.1s; }

        .hero-name {
            font-family: var(--font-display);
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.1;
            margin: 1.5rem 0 0.5rem;
            opacity: 0;
            animation: fadeUp 0.6s ease forwards 1.4s;
        }

        .hero-title {
            font-size: clamp(1rem, 2.5vw, 1.3rem);
            color: var(--accent-blue);
            font-weight: 400;
            margin-bottom: 1.5rem;
            opacity: 0;
            animation: fadeUp 0.6s ease forwards 1.7s;
        }

        .hero-bio {
            font-size: 0.85rem;
            color: var(--text-secondary);
            max-width: 600px;
            line-height: 1.8;
            opacity: 0;
            animation: fadeUp 0.6s ease forwards 2s;
        }

        .hero-links {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
            opacity: 0;
            animation: fadeUp 0.6s ease forwards 2.3s;
        }

        .hero-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 1.2rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 0.8rem;
            color: var(--text-secondary);
            transition: all 0.3s;
            background: transparent;
        }
        .hero-link:hover {
            border-color: var(--accent-blue);
            color: var(--accent-blue);
            box-shadow: 0 0 20px var(--glow-blue);
            background: rgba(88, 166, 255, 0.03);
        }
        .hero-link svg {
            width: 16px; height: 16px;
            fill: currentColor;
        }

        .cursor-blink {
            display: inline-block;
            width: 8px;
            height: 1.1em;
            background: var(--accent-green);
            margin-left: 4px;
            vertical-align: text-bottom;
            animation: blink 1s step-end infinite;
        }

        @keyframes blink {
            50% { opacity: 0; }
        }

        @keyframes typeIn {
            from { opacity: 0; transform: translateX(-8px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ═══════════════ SECTIONS ═══════════════ */
        section {
            padding: 5rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 3rem;
        }

        .section-header h2 {
            font-family: var(--font-display);
            font-size: 1.6rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .section-header .line {
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, var(--border), transparent);
        }

        .section-header .num {
            font-family: var(--font-mono);
            font-size: 0.85rem;
            color: var(--accent-green);
            font-weight: 400;
        }

        /* ═══════════════ SKILLS ═══════════════ */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.25rem;
        }

        .skill-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.5rem;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .skill-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 3px;
            height: 100%;
            background: var(--card-accent, var(--accent-blue));
            opacity: 0;
            transition: opacity 0.3s;
        }

        .skill-card:hover {
            border-color: var(--card-accent, var(--accent-blue));
            box-shadow: 0 0 30px rgba(0,0,0,0.3);
            transform: translateY(-2px);
        }
        .skill-card:hover::before { opacity: 1; }

        .skill-card-title {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--card-accent, var(--accent-blue));
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .skill-card-title .icon {
            font-size: 1rem;
            opacity: 0.8;
        }

        .skill-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .skill-tag {
            font-size: 0.75rem;
            padding: 0.3rem 0.7rem;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: 4px;
            color: var(--text-secondary);
            transition: all 0.2s;
        }

        .skill-tag:hover {
            border-color: var(--card-accent, var(--accent-blue));
            color: var(--card-accent, var(--accent-blue));
            background: var(--glow-blue);
        }

        /* ═══════════════ EXPERIENCE ═══════════════ */
        .timeline {
            position: relative;
            padding-left: 2rem;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 1px;
            background: linear-gradient(to bottom, var(--accent-green), var(--accent-blue), var(--border));
        }

        .timeline-item {
            position: relative;
            padding-bottom: 3rem;
        }
        .timeline-item:last-child { padding-bottom: 0; }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2rem;
            top: 0.5rem;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            background: var(--bg-primary);
            border: 2px solid var(--accent-green);
            z-index: 1;
        }

        .timeline-item.past::before {
            border-color: var(--accent-blue);
        }

        .timeline-date {
            font-size: 0.75rem;
            color: var(--accent-green);
            font-weight: 500;
            margin-bottom: 0.3rem;
        }

        .timeline-item.past .timeline-date {
            color: var(--accent-blue);
        }

        .timeline-role {
            font-family: var(--font-display);
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.15rem;
        }

        .timeline-company {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 1rem;
        }

        .timeline-projects {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .project-block {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1.25rem;
            transition: all 0.3s;
        }
        .project-block:hover {
            border-color: var(--accent-blue);
            box-shadow: 0 0 20px rgba(0,0,0,0.2);
        }

        .project-block h4 {
            font-size: 0.9rem;
            color: var(--accent-cyan);
            margin-bottom: 0.5rem;
            font-weight: 500;
        }

        .project-block p {
            font-size: 0.8rem;
            color: var(--text-secondary);
            line-height: 1.7;
            margin-bottom: 0.75rem;
        }

        .project-tech {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
        }

        .project-tech span {
            font-size: 0.7rem;
            padding: 0.2rem 0.5rem;
            background: rgba(88, 166, 255, 0.08);
            border-radius: 3px;
            color: var(--accent-blue);
        }

        /* ═══════════════ PROJECTS (GITHUB) ═══════════════ */
        .repos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 1.25rem;
        }

        .repo-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.5rem;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            text-decoration: none;
        }
        .repo-card:hover {
            border-color: var(--accent-blue);
            box-shadow: 0 0 30px rgba(0,0,0,0.3);
            transform: translateY(-2px);
        }

        .repo-card-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.75rem;
        }

        .repo-icon {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        .repo-card-header h3 {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--accent-blue);
        }

        .repo-desc {
            font-size: 0.8rem;
            color: var(--text-secondary);
            line-height: 1.6;
            flex: 1;
            margin-bottom: 1rem;
        }

        .repo-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .repo-lang {
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .lang-dot {
            width: 10px; height: 10px;
            border-radius: 50%;
        }

        /* ═══════════════ EDUCATION ═══════════════ */
        .edu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 1.25rem;
        }

        .edu-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.5rem;
        }

        .edu-card h3 {
            font-family: var(--font-display);
            font-size: 1rem;
            color: var(--text-primary);
            margin-bottom: 0.25rem;
        }

        .edu-card .institution {
            font-size: 0.8rem;
            color: var(--accent-blue);
            margin-bottom: 0.5rem;
        }

        .edu-card .edu-detail {
            font-size: 0.78rem;
            color: var(--text-secondary);
        }

        /* ═══════════════ CONTACT ═══════════════ */
        .contact-terminal {
            background: var(--bg-terminal);
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
        }

        .contact-body {
            padding: 2rem 2.5rem;
        }

        .contact-line {
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
        }

        .contact-line .key {
            color: var(--accent-purple);
        }
        .contact-line .sep {
            color: var(--text-muted);
        }
        .contact-line .val {
            color: var(--accent-cyan);
        }

        .contact-links {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .contact-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.7rem 1.5rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            color: var(--text-secondary);
            transition: all 0.3s;
            cursor: pointer;
            background: transparent;
        }

        .contact-btn:hover {
            border-color: var(--accent-green);
            color: var(--accent-green);
            box-shadow: 0 0 20px var(--glow-green);
        }

        /* ═══════════════ FOOTER ═══════════════ */
        footer {
            text-align: center;
            padding: 3rem 2rem;
            border-top: 1px solid var(--border);
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        footer .heart { color: var(--accent-red); }

        /* ═══════════════ RESPONSIVE ═══════════════ */
        @media (max-width: 768px) {
            .nav-links { display: none; }
            .nav-links.open {
                display: flex;
                flex-direction: column;
                position: absolute;
                top: 56px;
                left: 0; right: 0;
                background: rgba(10, 14, 20, 0.97);
                border-bottom: 1px solid var(--border);
                padding: 1rem;
            }
            .nav-toggle { display: block; }

            .terminal-body { padding: 1.5rem; }
            .hero-name { font-size: 2.2rem; }
            .skills-grid, .repos-grid, .edu-grid { grid-template-columns: 1fr; }
            .contact-body { padding: 1.5rem; }

            section { padding: 3rem 1.25rem; }
        }

        /* ═══════════════ SCROLL REVEAL ═══════════════ */
        .reveal {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ═══════════════ LANGUAGES ═══════════════ */
        .lang-grid {
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .lang-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .lang-name {
            font-size: 0.85rem;
            color: var(--text-primary);
            font-weight: 500;
        }

        .lang-level {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .lang-bar {
            width: 80px;
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
        }
        .lang-bar-fill {
            height: 100%;
            border-radius: 2px;
            background: var(--accent-green);
        }
    </style>
</head>
<body>

<!-- ═══════════════ NAV ═══════════════ -->
<nav>
    <div class="nav-inner">
        <div class="nav-logo">
            <span>~/</span>bruno-mirrado
        </div>
        <button class="nav-toggle" onclick="document.querySelector('.nav-links').classList.toggle('open')" aria-label="Toggle menu">☰</button>
        <ul class="nav-links">
            <li><a href="#skills">skills</a></li>
            <li><a href="#experience">experience</a></li>
            <li><a href="#projects">projects</a></li>
            <li><a href="#education">education</a></li>
            <li><a href="#contact">contact</a></li>
        </ul>
    </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="hero" id="hero">
    <div class="hero-inner">
        <div class="hero-terminal">
            <div class="terminal-bar">
                <div class="terminal-dot red"></div>
                <div class="terminal-dot yellow"></div>
                <div class="terminal-dot green"></div>
                <span class="terminal-title">bruno@portfolio — zsh</span>
            </div>
            <div class="terminal-body">
                <div class="hero-line">
                    <span class="prompt">❯</span>
                    <span class="path"> ~/portfolio</span>
                    <span class="cmd"> cat</span>
                    <span class="flag"> --about</span>
                    <span class="string"> ./bruno-mirrado</span>
                </div>
                <div class="hero-line">
                    <span class="comment"># Frontend Developer @ Merkle Portugal (dentsu Group)</span>
                </div>
                <div class="hero-line">
                    <span class="comment"># Lisbon, Portugal 🇵🇹</span>
                </div>
                <div class="hero-line">
                    <span class="prompt">❯</span>
                    <span class="cmd"> echo</span>
                    <span class="string"> $STACK</span>
                    <span class="cmd"> | React · TypeScript · Next.js · Vue · Tailwind · Azure · CI/CD</span>
                    <span class="cursor-blink"></span>
                </div>

                <h1 class="hero-name">Bruno Mirrado</h1>
